@startuml 端到端数据流转图
!theme plain
skinparam backgroundColor #FEFEFE
skinparam componentStyle rectangle

 title 图 1-2 端到端数据流转图

 component "外部任务源\n（上游系统 / 手动提交 / 批量导入）" as Source #E3F2FD

 queue "Kafka\n任务导入 Topic" as TaskTopic #FFF3E0

 component "任务导入器\n(Task Importer)" as Importer #FFF3E0 {
    portin json
    portout db
    component "操作: 消息解析 → 数据校验 →\n数据库写入 → 状态初始化 (PENDING)" as ImportOps
}

 database "SQLite\n数据库" as SQLite #E8F5E9 {
    component "状态: PENDING → RUNNING →\nCOMPLETED/FAILED" as StatusFlow
    component "记录: 任务元数据、执行参数、\n结果数据、LLM Token 统计" as Records
}

 component "任务执行器\n(Task Runner)" as Runner #FFF3E0 {
    component "操作: 状态检查 → 并发控制 →\nAgent 调用 → 浏览器自动化 → 结果捕获" as RunOps
 }

 component "任务报告器\n(Task Reporter)" as Reporter #FFF3E0 {
    component "操作: 结果组装 → 成功/失败分类 →\nKafka Topic 发送" as ReportOps
    component "格式: {task_id, status, result,\nduration, llm_usage, error_type...}" as ReportFormat
 }

 queue "Kafka\n结果上报 Topic" as ReportTopic #FFF3E0

 component "Report-Success\nTopic" as SuccessTopic #E8F5E9
 component "Report-Failed\nTopic" as FailedTopic #FFEBEE
 component "下游消费者\n(数据分析等)" as Consumers #E3F2FD

 Source --> TaskTopic : JSON 任务指令
 TaskTopic --> Importer : 消费
 Importer --> SQLite : 状态变更

 SQLite --> Runner : 轮询/事件触发
 Runner --> SQLite : 更新状态

 SQLite --> Reporter
 Reporter --> ReportTopic : 生产消息

 ReportTopic --> SuccessTopic
 ReportTopic --> FailedTopic
 SuccessTopic --> Consumers
 FailedTopic --> Consumers

@enduml
