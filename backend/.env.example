# ===== Python 核心 / 后端通用 (.env) =====
# OpenAI 配置
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai-proxy.org/v1
AGENT_MODEL=gpt-5.1-codex-mini

# Playwright 代理（可选）
PLAYWRIGHT_PROXY_SERVER=http://127.0.0.1:7890

# 巡检相关
INSPECT_MAX_MENU_ENTRIES=3

# LLM 回合截图开关（可选）
# 是否为每个 LLM 回合保存截图/DOM：1 开启，0 关闭
LLM_SNAPSHOT=1
# 截图是否使用全页：1 全页截图，0 仅视口
LLM_SNAPSHOT_FULLPAGE=1

# 后端 API（FastAPI）示例，可按需覆盖
PROJECT_NAME="Website Analytics API"
API_PREFIX=/api
