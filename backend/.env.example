# ===== Python 核心 / 后端通用 (.env) =====
# OpenAI 配置
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai-proxy.org/v1
AGENT_MODEL=gpt-5.1-codex-mini

# openai-agents 输出到 stdout 的详细调试日志（可选）
# 1 开启，0 关闭。建议生产环境保持 0，避免刷屏。
AGENTS_VERBOSE_STDOUT_LOGGING=0

# Playwright 代理（可选）
PLAYWRIGHT_PROXY_SERVER=http://127.0.0.1:7890
# Playwright 浏览器关闭超时时间（秒），用于等待视频编码和 trace 保存完成
PLAYWRIGHT_CLOSE_TIMEOUT_SECONDS=120
# 清理缓冲时间（秒），预留给 Playwright 清理和孤儿进程检测
PLAYWRIGHT_CLEANUP_BUFFER_SECONDS=120

# 巡检相关
INSPECT_MAX_MENU_ENTRIES=3

# LLM 回合截图开关（可选）
# 是否为每个 LLM 回合保存截图/DOM：1 开启，0 关闭
LLM_SNAPSHOT=1
# 截图是否使用全页：1 全页截图，0 仅视口
LLM_SNAPSHOT_FULLPAGE=1

# 后端 API（FastAPI）示例，可按需覆盖
PROJECT_NAME="Website Analytics API"
API_PREFIX=/api

# 数据库 / 认证
# SQLite 默认位置：backend/db/wa.db，无需配置也会自动创建
# 如果需要自定义路径，使用绝对路径：DATABASE_URL=sqlite:////abs/path/to/wa.db
SECRET_KEY=please-change-me
# 可选：启动时播种管理员账号（存在则刷新密码）
# ADMIN_SEED_USERNAME=admin
# ADMIN_SEED_PASSWORD=admin123
# 访问令牌有效期（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=86400

# 任务调度
TASK_RUNNER_ENABLED=1
TASK_RUNNER_INTERVAL_SECONDS=5
TASK_RUNNER_TIMEOUT_SECONDS=600
TASK_RUNNER_HEADLESS=0
TASK_RUNNER_MAX_CONCURRENT=1

# 任务清理
TASK_CLEANER_ENABLED=1
TASK_CLEANER_INTERVAL_SECONDS=5
TASK_CLEANER_TIMEOUT_SECONDS=900
